---
import Application from '../layouts/Application.astro';
import Spacer from '../components/Spacer.astro';
import TrackView from '../components/TrackView.astro';
import GoBack from '../components/GoBack.astro';
---

<Application title="404" description="The thing you're looking for doesn't exist (404).">
	<h1 class="c-heading">404<span class="c-heading--highlight">.</span></h1>

	<Spacer />

	<div class="markdown-container">
		<p>The thing you're looking for doesn't exist.</p>
	</div>

	<GoBack />
</Application>

<TrackView key="not-found" />
