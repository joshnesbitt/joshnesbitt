---
import Application from '../layouts/Application.astro';
import Spacer from '../components/Spacer.astro';
import TrackView from '../components/TrackView.astro';
import Directory from '../components/Directory.astro';
import GoBack from '../components/GoBack.astro';

const description = 'Josh speaks, hosts and moderates at technology events — on engineering leadership, AI and building communities.';

const engagements = [
	{ name: 'All Day Hey! — founder and host, ten editions', href: 'https://heypresents.com/conference', meta: '2017–2026' },
	{ name: 'The Reality of AI in Software Engineering Leadership', href: 'https://www.linkedin.com/events/softwareengineeringleadership-w7366370929024581633/', meta: '2025' },
	{ name: 'No more excuses — the real power of culture and Getting Things Done', href: 'https://www.youtube.com/playlist?list=PLJwhw5AkkoduXbcmEpd47h3WDBLHkY4Cj', meta: '2024' },
	{ name: 'Another Idea: How creativity can be found anywhere', href: 'https://www.youtube.com/watch?v=ZiGwbdJQjls', meta: '2022' },
	{ name: 'The Official CIO Summit: IT Confronts Climate Change', href: 'https://www.cio.com/article/191630/it-confronts-climate-change.html', meta: '2021' },
	{ name: 'Hey! Live: Why Cyber Security Needs to Hire More Anthropologists', href: 'https://heypresents.com/talks/why-the-cyber-security-industry-needs-to-hire-more-anthropologists', meta: '2021' },
	{ name: 'Hey! Live: Empathy at work', href: 'https://heypresents.com/talks/empathy-at-work', meta: '2020' },
	{ name: 'Hey! Live: Using the web for social good', href: 'https://heypresents.com/talks/using-the-web-for-social-good', meta: '2020' },
	{ name: 'An evening with Helen Sharman, Britain’s first astronaut', href: 'https://stac.works/notes/hosting-a-talk-by-helen-sharman-the-first-british-astronaut', meta: '2019' },
	{ name: 'Glug Leeds: The Rise of the Programmer', href: 'https://stac.works/speaking/the-rise-of-the-programmer.pdf', meta: '2016' }
];
---

<Application title="Speaking" description={description}>
	<h1 class="c-heading">Speaking</h1>

	<Spacer />

	<div class="markdown-container c-lede">
		<p>I speak, host and moderate at technology events — on engineering leadership, AI and building communities. If that sounds like a fit for your event, <a href="mailto:hello@stac.works">get in touch</a>.</p>
	</div>

	<Spacer />

	<h2 class="c-sub-heading">Topics</h2>

	<div class="markdown-container">
		<ul>
			<li><strong>Engineering leadership</strong> — building and leading high-performing product engineering teams, from startups to scale.</li>
			<li><strong>AI in software engineering</strong> — the reality of adoption, the discourse surrounding it, and what it means for how teams work.</li>
			<li><strong>Conferences and community</strong> — lessons from founding and running All Day Hey! for ten editions.</li>
			<li><strong>Hosting and moderation</strong> — MCing conferences, chairing panels and interviewing, honed across Off Script and live events.</li>
		</ul>
	</div>

	<Spacer />

	<h2 class="c-sub-heading">Selected engagements</h2>

	<Directory items={engagements} />

	<Spacer />

	<h2 class="c-sub-heading">Press kit</h2>

	<div class="markdown-container">
		<p>Everything you need to announce me at your event. Bios are free to copy and edit.</p>

		<p><a href="/headshot.jpg">Download headshot</a> (JPEG, 1365&times;2048).</p>

		<h3>One-liner</h3>

		<p>Josh Nesbitt is a CTO, conference founder and podcast host based in Leeds, UK.</p>

		<h3>Short bio</h3>

		<p>Josh Nesbitt is a CTO based in Leeds with over a decade leading engineering in product-led businesses. He founded All Day Hey!, one of the UK's longest-running independent technology conferences, and hosts Off Script, a podcast on engineering leadership and AI.</p>

		<h3>Long bio</h3>

		<p>Josh Nesbitt is a software engineer and technical leader based in Leeds, UK. He's been working on the web for twenty years, with companies ranging from indie start-ups to some of the largest organisations in the world. His work spans hands-on platform engineering to leading some of the best-performing teams in the industry, and he currently serves as CTO at Genio.</p>

		<p>Alongside his work as a CTO and consultant, Josh founded and ran All Day Hey!, an internationally recognised technology conference that ran for ten editions, and co-hosts Off Script, a podcast on engineering leadership and AI.</p>
	</div>

	<GoBack />
</Application>

<TrackView key="speaking" />
