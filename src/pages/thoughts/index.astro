---
import { getThoughts } from '../../utils/finders';

import Application from '../../layouts/Application.astro';
import Spacer from '../../components/Spacer.astro';
import TrackView from '../../components/TrackView.astro';
import ThoughtList from '../../components/ThoughtList.astro';
import GoBack from '../../components/GoBack.astro';

const thoughts = await getThoughts();
---

<Application title="Thoughts">
  <h1 class="c-heading">Thoughts<span class="c-heading--highlight">.</span></h1>

  <Spacer />

  <ThoughtList thoughts={thoughts} />

  <GoBack />
</Application>

<TrackView namespace="thoughts" key="index" />
