---
import { render } from 'astro:content';
import getReadingTime from 'reading-time';
import Application from './Application.astro';
import Spacer from '../components/Spacer.astro';
import Directory from '../components/Directory.astro';
import { getRelatedThoughts } from '../utils/finders';

const item = Astro.props
const { Content } = await render(item);
const readingTime = getReadingTime(item.body);
const data = Astro.props.data;
const date = data.pubDate;

const related = item.collection === 'thought' ? await getRelatedThoughts(item) : [];

const relatedItems = related.map((rec) => ({
	name: rec.data.title,
	href: `/thoughts/${rec.id}`,
	meta: rec.data.pubDate.toLocaleDateString('en-uk', { year: 'numeric', month: 'short' })
}));

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`/api/og${Astro.url.pathname.replace(/\/$/, '')}.png`, Astro.site);

const schema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: data.title,
	description: data.description,
	datePublished: date.toISOString(),
	url: canonicalURL.toString(),
	image: ogImageURL.toString(),
	author: {
		'@type': 'Person',
		name: 'Josh Nesbitt',
		url: 'https://joshnesbitt.dev',
	},
};
---

<Application {...data} type="article" container="large">
	<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
	<h1 class="c-heading">{data.title}</h1>

	<Spacer />

	<div class="markdown-container">
		<p class="text-lg font-bold">
			<time datetime={date.toISOString()} >
				{date.toLocaleDateString('en-uk', {
			    year: 'numeric',
			    month: 'short'
			  })}

				·

				{readingTime.text}
			</time>
		</p>

		<Content />
	</div>

	{related.length > 0 && (
		<Fragment>
			<Spacer />

			<h2 class="c-sub-heading">Keep reading</h2>

			<Directory items={relatedItems} />
		</Fragment>
	)}

	<div class="markdown-container">
		<p>
			<a href="/">Go back</a>
		</p>
	</div>
</Application>
